# Site
PUBLIC_SITE_NAME="Janbao"
# Whether users/admins are allowed to change their profile URL slug / username ("true" or "false")
ALLOW_SLUG_CHANGE="false"

# Admin Bootstrap
# These are used to create the initial admin user on first run.
# Only takes effect when the database has no regular users yet.
# If skipped, there is no built-in way to create an admin later.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# Cloudflare D1
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_DATABASE_ID=""
CLOUDFLARE_D1_TOKEN=""

# pCloud image storage (WebDAV)
# Verify credentials and create the /avatars + /attachments folders by running:
#   bun scripts/setup-pcloud.ts   (it fills these in for you)
# For production, set the same via wrangler secret put.
# WebDAV uses email + password (Basic auth) on every request  - the account must
# NOT have 2FA enabled. EU: ewebdav.pcloud.com, US: webdav.pcloud.com.
PCLOUD_USERNAME=""
PCLOUD_PASSWORD=""
PCLOUD_WEBDAV_HOST="ewebdav.pcloud.com"
PCLOUD_BASE_PATH="/Janbao"

# SMTP Mailer Settings
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_AUTH_TYPE="plain"
SMTP_FROM_NAME="Janbao"
SMTP_FROM_EMAIL=""

